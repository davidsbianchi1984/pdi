<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PdiVault.Views.TransfersPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource PdiScrBotBrush}">

    <ScrollViewer>
        <StackPanel MaxWidth="640" Spacing="14" Padding="28" HorizontalAlignment="Left">
            <TextBlock Text="Transfers" FontSize="22" FontWeight="Bold" Foreground="{StaticResource PdiTxtBrush}" />
            <TextBlock Text="Seal a file for a recipient under compliance controls. Retention follows the strictest program you pick."
                       Foreground="{StaticResource PdiT2Brush}" FontSize="13" TextWrapping="Wrap" />

            <Border Background="{StaticResource PdiCardBrush}" BorderBrush="{StaticResource PdiLineBrush}"
                    BorderThickness="1" CornerRadius="16" Padding="16">
                <StackPanel Spacing="10">
                    <TextBox x:Name="RecipientBox" Header="Recipient" PlaceholderText="who it's for" />
                    <TextBox x:Name="FilenameBox" Header="Filename" PlaceholderText="e.g. results.pdf" />
                    <TextBox x:Name="ContentBox" Header="Content" PlaceholderText="the file body to seal"
                             AcceptsReturn="True" TextWrapping="Wrap" Height="70" />
                    <ItemsControl x:Name="ProgramChips">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding Key}" IsChecked="{Binding Selected, Mode=TwoWay}"
                                          Foreground="{StaticResource PdiTxtBrush}" MinWidth="0" Margin="0,0,8,0" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Button x:Name="CreateButton" Content="Seal &amp; create" HorizontalAlignment="Stretch"
                            Height="42" Foreground="White" Click="OnCreate">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="{StaticResource PdiBrandA}" Offset="0" />
                                <GradientStop Color="#FF3AA0FF" Offset="1" />
                            </LinearGradientBrush>
                        </Button.Background>
                    </Button>
                </StackPanel>
            </Border>

            <TextBlock x:Name="ErrorText" Foreground="{StaticResource PdiRed}" FontSize="13"
                       TextWrapping="Wrap" Visibility="Collapsed" />

            <Border x:Name="TokenCard" Background="{StaticResource PdiCardBrush}"
                    BorderBrush="{StaticResource PdiLineBrush}" BorderThickness="1" CornerRadius="16"
                    Padding="16" Visibility="Collapsed">
                <StackPanel Spacing="6">
                    <TextBlock Text="Receive token — shown once" FontWeight="Bold" FontSize="15"
                               Foreground="{StaticResource PdiTxtBrush}" />
                    <TextBlock x:Name="TokenText" FontFamily="Consolas" FontSize="12"
                               Foreground="{StaticResource PdiT2Brush}" TextWrapping="Wrap" />
                    <TextBlock Text="Hand this to the recipient out of band; it is the only way to retrieve the file."
                               Foreground="{StaticResource PdiT2Brush}" FontSize="12" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <ItemsControl x:Name="TransfersList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource PdiCardBrush}" BorderBrush="{StaticResource PdiLineBrush}"
                                BorderThickness="1" CornerRadius="14" Padding="14" Margin="0,0,0,8">
                            <StackPanel Spacing="4">
                                <Grid>
                                    <TextBlock Text="{Binding Filename}" FontWeight="Bold"
                                               Foreground="{StaticResource PdiTxtBrush}" />
                                    <TextBlock Text="{Binding Status}" HorizontalAlignment="Right"
                                               Foreground="{StaticResource PdiT2Brush}" FontSize="12" />
                                </Grid>
                                <TextBlock Text="{Binding Meta}" Foreground="{StaticResource PdiT2Brush}" FontSize="12" />
                                <Button Content="Revoke access" Tag="{Binding Id}" Click="OnRevoke"
                                        Visibility="{Binding RevokeVisibility}"
                                        Background="Transparent" Foreground="{StaticResource PdiRed}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</Page>
