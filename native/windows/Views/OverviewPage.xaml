<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PdiVault.Views.OverviewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource PdiScrBotBrush}">

    <ScrollViewer>
        <StackPanel MaxWidth="640" Spacing="14" Padding="28" HorizontalAlignment="Left">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Ellipse Width="9" Height="9" Fill="{StaticResource PdiGreenBrush}" VerticalAlignment="Center" />
                <TextBlock Text="Vault unlocked" Foreground="{StaticResource PdiGreenBrush}"
                           FontWeight="Bold" FontSize="12" />
            </StackPanel>
            <TextBlock Text="Your vault" FontSize="28" FontWeight="Bold" Foreground="{StaticResource PdiTxtBrush}" />
            <TextBlock Text="Records are sealed at rest; every access is hash-chained in the audit log."
                       Foreground="{StaticResource PdiT2Brush}" FontSize="14" TextWrapping="Wrap" />

            <StackPanel Orientation="Horizontal" Spacing="12">
                <Border Background="{StaticResource PdiCardBrush}" BorderBrush="{StaticResource PdiLineBrush}"
                        BorderThickness="1" CornerRadius="16" Padding="16" MinWidth="150">
                    <StackPanel Spacing="4">
                        <TextBlock x:Name="RecordsValue" Text="—" FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource PdiBrandABrush}" />
                        <TextBlock Text="Records" Foreground="{StaticResource PdiT2Brush}" FontSize="12" />
                    </StackPanel>
                </Border>
                <Border Background="{StaticResource PdiCardBrush}" BorderBrush="{StaticResource PdiLineBrush}"
                        BorderThickness="1" CornerRadius="16" Padding="16" MinWidth="150">
                    <StackPanel Spacing="4">
                        <TextBlock x:Name="AuditValue" Text="—" FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource PdiGreenBrush}" />
                        <TextBlock Text="Audit" Foreground="{StaticResource PdiT2Brush}" FontSize="12" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <Border Background="{StaticResource PdiCardBrush}" BorderBrush="{StaticResource PdiLineBrush}"
                    BorderThickness="1" CornerRadius="16" Padding="16">
                <StackPanel Spacing="6">
                    <TextBlock Text="Token" FontWeight="Bold" FontSize="16" Foreground="{StaticResource PdiTxtBrush}" />
                    <TextBlock x:Name="TokenText" FontFamily="Consolas" Foreground="{StaticResource PdiT2Brush}" />
                    <TextBlock x:Name="BaseText" FontSize="12" Foreground="{StaticResource PdiT2Brush}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
