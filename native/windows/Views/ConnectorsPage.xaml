<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PdiVault.Views.ConnectorsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource PdiScrBotBrush}">

    <ScrollViewer>
        <StackPanel MaxWidth="640" Spacing="14" Padding="28" HorizontalAlignment="Left">
            <TextBlock Text="Connectors" FontSize="22" FontWeight="Bold" Foreground="{StaticResource PdiTxtBrush}" />
            <TextBlock Text="Link a platform account. Collected content is sealed into the vault; every ingest is hash-chained in the audit log."
                       Foreground="{StaticResource PdiT2Brush}" FontSize="13" TextWrapping="Wrap" />

            <Border Background="{StaticResource PdiCardBrush}" BorderBrush="{StaticResource PdiLineBrush}"
                    BorderThickness="1" CornerRadius="16" Padding="16">
                <StackPanel Spacing="10">
                    <ComboBox x:Name="PlatformBox" Header="Platform" HorizontalAlignment="Stretch" />
                    <TextBox x:Name="HandleBox" Header="Handle (optional)" PlaceholderText="@account" />
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button Content="Connect to collect" Click="OnConnectCollect"
                                Background="Transparent" Foreground="{StaticResource PdiBrandABrush}" />
                        <Button Content="Connect to publish" Click="OnConnectPublish"
                                Background="Transparent" Foreground="{StaticResource PdiBrandABrush}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <TextBlock x:Name="ErrorText" Foreground="{StaticResource PdiRed}" FontSize="13"
                       TextWrapping="Wrap" Visibility="Collapsed" />
            <TextBlock x:Name="StatusText" Foreground="{StaticResource PdiGreenBrush}" FontSize="12"
                       Visibility="Collapsed" />

            <ItemsControl x:Name="ConnsList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource PdiCardBrush}" BorderBrush="{StaticResource PdiLineBrush}"
                                BorderThickness="1" CornerRadius="14" Padding="14" Margin="0,0,0,8">
                            <StackPanel Spacing="6">
                                <Grid>
                                    <TextBlock Text="{Binding Title}" FontWeight="Bold"
                                               Foreground="{StaticResource PdiTxtBrush}" />
                                    <TextBlock Text="{Binding Handle}" HorizontalAlignment="Right"
                                               Foreground="{StaticResource PdiT2Brush}" FontSize="12" />
                                </Grid>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Content="Ingest sample" Tag="{Binding Id}" Click="OnIngest"
                                            Visibility="{Binding IngestVisibility}"
                                            Background="Transparent" Foreground="{StaticResource PdiBrandABrush}" />
                                    <Button Content="Publish update" Tag="{Binding Id}" Click="OnPublish"
                                            Visibility="{Binding PublishVisibility}"
                                            Background="Transparent" Foreground="{StaticResource PdiBrandABrush}" />
                                    <Button Content="Disconnect" Tag="{Binding Id}" Click="OnRevoke"
                                            Background="Transparent" Foreground="{StaticResource PdiRed}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</Page>
