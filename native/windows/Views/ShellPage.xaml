<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PdiVault.Views.ShellPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource PdiScrBotBrush}">

    <NavigationView x:Name="Nav" IsBackButtonVisible="Collapsed" IsSettingsVisible="False"
                    PaneDisplayMode="Left" SelectionChanged="OnSelectionChanged"
                    Background="{StaticResource PdiScrBotBrush}">
        <NavigationView.MenuItems>
            <NavigationViewItem Content="Overview" Tag="overview" IsSelected="True">
                <NavigationViewItem.Icon><SymbolIcon Symbol="Home" /></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Vault" Tag="vault">
                <NavigationViewItem.Icon><SymbolIcon Symbol="ProtectedDocument" /></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Audit" Tag="audit">
                <NavigationViewItem.Icon><SymbolIcon Symbol="Accept" /></NavigationViewItem.Icon>
            </NavigationViewItem>
        </NavigationView.MenuItems>
        <NavigationView.PaneFooter>
            <Button Content="Sign out" Margin="12" Click="OnSignOut"
                    Foreground="{StaticResource PdiT2Brush}" Background="Transparent" />
        </NavigationView.PaneFooter>
        <Frame x:Name="ContentFrame" />
    </NavigationView>
</Page>
