<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PdiVault.Views.RobotsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource PdiScrBotBrush}">

    <ScrollViewer>
        <StackPanel MaxWidth="640" Spacing="14" Padding="28" HorizontalAlignment="Left">
            <TextBlock Text="Robots" FontSize="22" FontWeight="Bold" Foreground="{StaticResource PdiTxtBrush}" />
            <TextBlock Text="What your robots see stays sealed — every intake is encrypted at rest and hash-chained in the audit log."
                       Foreground="{StaticResource PdiT2Brush}" FontSize="13" TextWrapping="Wrap" />

            <Border Background="{StaticResource PdiCardBrush}" BorderBrush="{StaticResource PdiLineBrush}"
                    BorderThickness="1" CornerRadius="16" Padding="16">
                <StackPanel Spacing="10">
                    <ComboBox x:Name="ModelBox" Header="Bind a robot" HorizontalAlignment="Stretch" />
                    <Button x:Name="BindButton" Content="Bind" HorizontalAlignment="Stretch"
                            Height="42" Foreground="White" Click="OnBind">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="{StaticResource PdiBrandA}" Offset="0" />
                                <GradientStop Color="#FF3AA0FF" Offset="1" />
                            </LinearGradientBrush>
                        </Button.Background>
                    </Button>
                </StackPanel>
            </Border>

            <TextBlock x:Name="ErrorText" Foreground="{StaticResource PdiRed}" FontSize="13"
                       TextWrapping="Wrap" Visibility="Collapsed" />

            <ItemsControl x:Name="RobotsList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource PdiCardBrush}" BorderBrush="{StaticResource PdiLineBrush}"
                                BorderThickness="1" CornerRadius="14" Padding="14" Margin="0,0,0,8">
                            <StackPanel Spacing="8">
                                <Grid>
                                    <TextBlock Text="{Binding Name}" FontWeight="Bold"
                                               Foreground="{StaticResource PdiTxtBrush}" />
                                    <TextBlock Text="{Binding Sealed}" HorizontalAlignment="Right"
                                               Foreground="{StaticResource PdiGreenBrush}" FontSize="12" />
                                </Grid>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Content="Seal map" Tag="{Binding Id}" Click="OnSealMap"
                                            Background="Transparent" Foreground="{StaticResource PdiBrandABrush}" />
                                    <Button Content="Snapshot" Tag="{Binding Id}" Click="OnSealSnapshot"
                                            Background="Transparent" Foreground="{StaticResource PdiBrandABrush}" />
                                    <Button Content="Sensor log" Tag="{Binding Id}" Click="OnSealSensor"
                                            Background="Transparent" Foreground="{StaticResource PdiBrandABrush}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border x:Name="ResultCard" Background="{StaticResource PdiCardBrush}"
                    BorderBrush="{StaticResource PdiLineBrush}" BorderThickness="1" CornerRadius="16"
                    Padding="16" Visibility="Collapsed">
                <StackPanel Spacing="6">
                    <TextBlock Text="Sealed" FontWeight="Bold" FontSize="16"
                               Foreground="{StaticResource PdiTxtBrush}" />
                    <TextBlock x:Name="KeyText" FontFamily="Consolas" FontSize="12"
                               Foreground="{StaticResource PdiT2Brush}" TextWrapping="Wrap" />
                    <TextBlock Text="Read it (audited) via Vault → the key above."
                               Foreground="{StaticResource PdiT2Brush}" FontSize="12" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
