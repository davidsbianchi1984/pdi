<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PdiVault.Views.AuditPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource PdiScrBotBrush}">

    <ScrollViewer>
        <StackPanel MaxWidth="640" Spacing="14" Padding="28" HorizontalAlignment="Left">
            <TextBlock Text="Audit" FontSize="22" FontWeight="Bold" Foreground="{StaticResource PdiTxtBrush}" />
            <TextBlock Text="Every vault action is hash-chained. Verify recomputes the whole chain."
                       Foreground="{StaticResource PdiT2Brush}" FontSize="13" TextWrapping="Wrap" />

            <Border Background="{StaticResource PdiCardBrush}" BorderBrush="{StaticResource PdiLineBrush}"
                    BorderThickness="1" CornerRadius="16" Padding="16">
                <StackPanel Spacing="4">
                    <TextBlock x:Name="StatusText" Text="Verifying…" FontWeight="Bold" FontSize="16"
                               Foreground="{StaticResource PdiGreenBrush}" />
                    <TextBlock x:Name="CountText" Text="0 recorded events"
                               Foreground="{StaticResource PdiT2Brush}" FontSize="12" />
                </StackPanel>
            </Border>

            <ItemsControl x:Name="EntriesList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource PdiCardBrush}" BorderBrush="{StaticResource PdiLineBrush}"
                                BorderThickness="1" CornerRadius="16" Padding="14" Margin="0,0,0,8">
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Seq}" Foreground="{StaticResource PdiT2Brush}"
                                           FontFamily="Consolas" VerticalAlignment="Center" />
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding Action}" FontWeight="Bold"
                                               Foreground="{StaticResource PdiTxtBrush}" />
                                    <TextBlock Text="{Binding Ref}" Foreground="{StaticResource PdiT2Brush}" FontSize="12" />
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="{Binding Category}" VerticalAlignment="Center"
                                           Foreground="{StaticResource PdiBrandABrush}" FontSize="12" FontWeight="Bold" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</Page>
