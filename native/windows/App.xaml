<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="PdiVault.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <!-- PDI Vault dark-OLED palette -->
            <Color x:Key="PdiScrBot">#FF0A0F1C</Color>
            <Color x:Key="PdiCard">#FF182238</Color>
            <Color x:Key="PdiLine">#FF26314E</Color>
            <Color x:Key="PdiTxt">#FFEEF1F7</Color>
            <Color x:Key="PdiT2">#FF8A94AD</Color>
            <Color x:Key="PdiBrandA">#FF7C5CFF</Color>
            <Color x:Key="PdiGreen">#FF43E08A</Color>
            <Color x:Key="PdiRed">#FFFF3B30</Color>
            <SolidColorBrush x:Key="PdiScrBotBrush" Color="{StaticResource PdiScrBot}" />
            <SolidColorBrush x:Key="PdiCardBrush" Color="{StaticResource PdiCard}" />
            <SolidColorBrush x:Key="PdiLineBrush" Color="{StaticResource PdiLine}" />
            <SolidColorBrush x:Key="PdiTxtBrush" Color="{StaticResource PdiTxt}" />
            <SolidColorBrush x:Key="PdiT2Brush" Color="{StaticResource PdiT2}" />
            <SolidColorBrush x:Key="PdiBrandABrush" Color="{StaticResource PdiBrandA}" />
            <SolidColorBrush x:Key="PdiGreenBrush" Color="{StaticResource PdiGreen}" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
